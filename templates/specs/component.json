{"spec_version": "1.0", "metadata": {"name": "button-component", "type": "component", "version": "1.0.0", "author": "", "created": "", "updated": ""}, "description": "通用按钮组件规格", "props": [{"name": "label", "type": "string", "required": true, "default": "", "description": "按钮文本"}, {"name": "variant", "type": "enum", "values": ["primary", "secondary", "danger", "ghost"], "required": false, "default": "primary", "description": "按钮样式变体"}, {"name": "size", "type": "enum", "values": ["small", "medium", "large"], "required": false, "default": "medium", "description": "按钮大小"}, {"name": "disabled", "type": "boolean", "required": false, "default": false, "description": "是否禁用"}, {"name": "loading", "type": "boolean", "required": false, "default": false, "description": "是否显示加载状态"}], "events": [{"name": "click", "description": "按钮点击事件", "payload": {"event": "MouseEvent"}}], "slots": [{"name": "default", "description": "默认插槽，可自定义按钮内容"}], "methods": [{"name": "focus", "description": "聚焦按钮", "returns": "void"}, {"name": "blur", "description": "取消聚焦", "returns": "void"}], "examples": [{"description": "基础用法", "code": "<Button label=\"提交\" variant=\"primary\" />"}, {"description": "加载状态", "code": "<Button label=\"提交中...\" loading />"}]}