{"spec_version": "1.0", "metadata": {"name": "email-service", "type": "service", "version": "1.0.0", "author": "", "created": "", "updated": ""}, "description": "邮件发送服务规格", "interfaces": [{"name": "IEmailService", "methods": [{"name": "send", "description": "发送邮件", "parameters": [{"name": "to", "type": "string", "required": true, "description": "收件人邮箱"}, {"name": "subject", "type": "string", "required": true, "description": "邮件主题"}, {"name": "body", "type": "string", "required": true, "description": "邮件内容"}, {"name": "attachments", "type": "array", "required": false, "description": "附件列表"}], "returns": {"type": "object", "properties": {"success": {"type": "boolean"}, "messageId": {"type": "string"}, "error": {"type": "string"}}}}, {"name": "sendTemplate", "description": "使用模板发送邮件", "parameters": [{"name": "to", "type": "string", "required": true, "description": "收件人邮箱"}, {"name": "templateId", "type": "string", "required": true, "description": "模板ID"}, {"name": "data", "type": "object", "required": true, "description": "模板数据"}], "returns": {"type": "object", "properties": {"success": {"type": "boolean"}, "messageId": {"type": "string"}, "error": {"type": "string"}}}}]}], "dependencies": [{"name": "smtp-client", "version": ">=1.0.0", "type": "external"}], "configuration": {"host": {"type": "string", "required": true, "description": "SMTP 服务器地址"}, "port": {"type": "integer", "required": true, "default": 587, "description": "SMTP 端口"}, "username": {"type": "string", "required": true, "description": "SMTP 用户名"}, "password": {"type": "string", "required": true, "description": "SMTP 密码"}, "from": {"type": "string", "required": true, "description": "发件人邮箱"}}}